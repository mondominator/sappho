PORT=3001
NODE_ENV=development
# REQUIRED: Generate a strong secret (min 32 chars). Example:
#   openssl rand -base64 32
JWT_SECRET=
# REQUIRED: Generate a strong encryption key (min 32 chars). Example:
#   openssl rand -base64 48
ENCRYPTION_KEY=
DATABASE_PATH=./data/sappho.db
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
AUDIOBOOKS_DIR=./data/audiobooks
LIBRARY_SCAN_INTERVAL=5
# Optional: Hardcover.app API key for book metadata search
# Get your key at https://hardcover.app/settings#api
# API is in beta - tokens expire after 1 year and reset on January 1st
# Rate limit: 60 requests/minute
HARDCOVER_API_KEY=
