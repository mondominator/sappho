PORT=3001
NODE_ENV=development
# REQUIRED: Generate a strong secret (min 32 chars). Example:
#   openssl rand -base64 32
JWT_SECRET=
DATABASE_PATH=./data/sappho.db
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
AUDIOBOOKS_DIR=./data/audiobooks
LIBRARY_SCAN_INTERVAL=5
# Optional: Hardcover.app API key for book metadata search
# Get your key at https://hardcover.app/settings#api
# API is in beta - tokens expire after 1 year and reset on January 1st
# Rate limit: 60 requests/minute
# Leave empty or comment out to disable Hardcover search
HARDCOVER_API_KEY=

# Optional: Number of results to fetch from Hardcover API (default: 10, max: 50)
# HARDCOVER_RESULTS_LIMIT=10

# Optional: Hardcover OAuth credentials for user account integration
# Register your app at https://hardcover.app/oauth/applications
# HARDCOVER_OAUTH_CLIENT_ID=
# HARDCOVER_OAUTH_CLIENT_SECRET=
# HARDCOVER_OAUTH_REDIRECT_URI=http://localhost:3003/api/hardcover/oauth/callback

# Optional: Encryption key for storing sensitive data (OAuth tokens, API keys)
# Generate with: openssl rand -hex 32
# If not set, a key will be auto-generated on startup (will change on restart)
# ENCRYPTION_KEY=
